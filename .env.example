# Copy this file to `.env.local` for local dev.
# Both URLs should point at your Laravel API root (without trailing slash).

VITE_API_URL=https://api.kamiledu.test/api
VITE_AI_API_URL=https://ai.kamiledu.test/api

# Optional: Google OAuth client ID for Google Sign-In
VITE_GOOGLE_CLIENT_ID=

# Optional: support WhatsApp number for the login "Hubungi admin" link.
# Matches Flutter default (https://wa.me/6285179819002).
VITE_WHATSAPP_SUPPORT=6285179819002

# Optional: Midtrans Snap client key — powers the /subscribe payment
# popup. Use the sandbox key (https://dashboard.sandbox.midtrans.com)
# for dev, the production key for prod. When empty, /subscribe still
# works via the manual bank-transfer fallback.
VITE_MIDTRANS_CLIENT_KEY=

# Realtime notifications via Laravel Reverb (Pusher-protocol compatible).
# INERT BY DEFAULT: leave VITE_REVERB_APP_KEY empty to disable realtime —
# the app then relies on polling only and never opens a WebSocket. Set
# these (matching the backend REVERB_* env) to activate live bell updates.
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
